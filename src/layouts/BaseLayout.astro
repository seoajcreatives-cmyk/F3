---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Tracker from '@components/Tracker.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  author?: string;
  bodyClass?: string;
}

const { 
  title, 
  description, 
  canonical, 
  author = "Aj Creative Studios",
  bodyClass = "" 
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Defer render-blocking stylesheets using MutationObserver -->
    <script is:inline>
      (function() {
        const observer = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            for (const node of mutation.addedNodes) {
              if (node.tagName === 'LINK' && node.rel === 'stylesheet') {
                const href = node.getAttribute('href') || '';
                // Target bundled Astro CSS files and Swiper CSS
                if (href.includes('_astro/') || href.includes('swiper')) {
                  node.setAttribute('media', 'print');
                  node.setAttribute('onload', "this.media='all'");
                }
              }
            }
          }
        });
        observer.observe(document.documentElement, { childList: true, subtree: true });
        
        // Disconnect observer after page load
        window.addEventListener('load', () => {
          observer.disconnect();
        });
      })();
    </script>

    <!-- Inline Critical CSS (Above-the-fold) -->
    <style is:inline>
      :root {
        --red: #e31e24;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: 'Poppins', sans-serif;
        overflow-x: hidden;
        background-color: #fff;
      }
      header {
        width: 100%;
        position: sticky;
        top: 0;
        left: 0;
        z-index: 100;
        background: #fff;
      }
      header .mobile-header {
        display: none;
      }
      header .line-address {
        background: var(--red);
        display: flex;
        justify-content: space-around;
        padding: 7px;
        align-items: center;
      }
      header .line-address .social-icon {
        display: flex;
        gap: 20px;
        align-items: center;
      }
      header .line-address .social-icon a {
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, opacity 0.2s ease;
      }
      header .line-address .social-icon a:hover {
        transform: scale(1.2);
        color: white;
        opacity: 0.85;
      }
      header .line-address > a {
        display: flex;
        gap: 8px;
        color: white;
        justify-content: center;
        align-items: center;
        text-decoration: none;
        font-size: 14px;
        transition: opacity 0.2s ease;
      }
      header .line-address > a svg,
      header .line-address .social-icon a svg {
        height: 16px !important;
        width: auto !important;
        fill: currentColor;
        flex-shrink: 0;
        display: block;
      }
      header .line-address > a:hover {
        opacity: 0.85;
        color: white;
      }
      header .header-desktop {
        display: grid;
        grid-template-columns: 70% 30%;
      }
      header .header-desktop .header-left {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2% 5%;
        background-color: #fff;
      }
      header .header-desktop .header-left .logo {
        width: 160px;
        flex-shrink: 0;
      }
      header .header-desktop .header-left .logo img {
        width: 100%;
        height: auto;
        display: block;
      }
      header .header-desktop .header-left .bbb-logo {
        width: 150px;
        flex-shrink: 0;
      }
      header .header-desktop .header-left .menu ul {
        display: flex;
        gap: 30px;
        list-style: none;
      }
      header .header-desktop .header-left .menu a {
        font-weight: 500;
        position: relative;
        color: #000;
        text-decoration: none;
      }
      header .header-desktop .header-right {
        background: var(--red);
        padding: 3% 10%;
        display: grid;
        grid-template-columns: 1fr;
        align-items: center;
      }
      header .header-desktop .header-right .contact-button {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      header .header-desktop .header-right .contact-button a {
        background: linear-gradient(to right, transparent 50%, #fff 50%);
        width: fit-content;
        padding: 2% 10%;
        border: 2px solid #fff;
        font-weight: 700;
        background-size: 200%;
        background-position: 100%;
        transform: skewX(-15deg);
        display: flex;
        justify-content: center;
        align-items: center;
        color: var(--red);
        text-decoration: none;
      }
      .banner-section {
        width: 100vw;
        height: 100vh;
        min-height: 100vh;
        padding: 0;
        position: relative;
        overflow: hidden;
      }
      .banner-section .banner-container {
        display: flex;
        position: relative;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        width: 100%;
        height: 100%;
        min-height: 100vh;
      }
      .banner-container video, .banner-container img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
      }
      .banner-section .banner-container .banner-content {
        display: flex;
        position: relative;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 2;
      }
      .banner-section .banner-container .banner-content h1 {
        color: white;
        line-height: 35px;
        font-size: 25px;
        text-align: center;
        font-weight: 500;
      }
      .banner-section .banner-container .banner-content span {
        font-size: 35px;
        font-weight: 700;
      }
      .banner-section .banner-container .banner-content a {
        background: linear-gradient(to right, white 50%, var(--red) 50%);
        width: fit-content;
        padding: 12px 42px;
        font-weight: 700;
        background-size: 200%;
        background-position: 100%;
        transform: skewX(-15deg);
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        text-decoration: none;
      }
      @media (max-width: 996px) {
        header .header-desktop {
          display: none;
        }
        header .mobile-header {
          display: block;
        }
        header .mobile-header .mobile-header-container {
          padding: 10px 5% !important;
          display: flex;
          justify-content: space-between;
          align-items: center;
          position: relative;
          background-color: #fff;
        }
        header .mobile-header .mobile-header-container .logo {
          display: flex;
          justify-content: center;
          align-items: center;
          width: 40% !important;
          max-width: 150px !important;
        }
        header .mobile-header .mobile_toggle {
          width: 40px;
          height: 40px;
          position: absolute;
          display: flex;
          right: 5%;
          top: 50%;
          transform: translateY(-50%);
          border-radius: 50px;
          flex-direction: column;
          align-items: flex-end;
          padding: 10px;
          background: white;
          box-shadow: -1px 1px 3px #00000030;
          z-index: 99;
        }
        .banner-section {
          width: 100%;
          height: auto;
          min-height: auto;
          aspect-ratio: 16 / 9;
        }
        .banner-section .banner-container {
          width: 100%;
          height: auto;
          min-height: auto;
          aspect-ratio: 16 / 9;
        }
      }
    </style>

    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content={author} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>

    <!-- Favicon & Touch Icons -->
    <link rel="shortcut icon" href="https://f3constructionny.com/media/iconified/favicon.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" href={base + "media/iconified/apple-touch-icon.png"} />
    <link rel="apple-touch-icon" sizes="57x57" href={base + "media/iconified/apple-touch-icon-57x57.png"} />
    <link rel="apple-touch-icon" sizes="72x72" href={base + "media/iconified/apple-touch-icon-72x72.png"} />
    <link rel="apple-touch-icon" sizes="76x76" href={base + "media/iconified/apple-touch-icon-76x76.png"} />
    <link rel="apple-touch-icon" sizes="114x114" href={base + "media/iconified/apple-touch-icon-114x114.png"} />
    <link rel="apple-touch-icon" sizes="120x120" href={base + "media/iconified/apple-touch-icon-120x120.png"} />
    <link rel="apple-touch-icon" sizes="144x144" href={base + "media/iconified/apple-touch-icon-144x144.png"} />
    <link rel="apple-touch-icon" sizes="152x152" href={base + "media/iconified/apple-touch-icon-152x152.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={base + "media/iconified/apple-touch-icon-180x180.png"} />

    <!-- Preloads & Fonts -->
    <link rel="preload" as="image" href={`${base}hero.webp`} fetchpriority="high" />
    
    <!-- Local self-hosted Poppins fonts preloads -->
    <link rel="preload" as="font" href={`${base}fonts/poppins-400.woff2`} type="font/woff2" crossorigin />
    <link rel="preload" as="font" href={`${base}fonts/poppins-500.woff2`} type="font/woff2" crossorigin />
    <link rel="preload" as="font" href={`${base}fonts/poppins-600.woff2`} type="font/woff2" crossorigin />
    <link rel="preload" as="font" href={`${base}fonts/poppins-700.woff2`} type="font/woff2" crossorigin />

    <!-- CSS libraries -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" media="print" onload="this.media='all'" />
    
    <!-- Custom Contact Form Handler Script -->
    <script src={base + "js/contact-handler.js"} defer></script>

    <!-- Page Specific head tags placeholder -->
    <slot name="head" />

    <!-- Trackers Integration -->
    <Tracker />
  </head>
  <body class={bodyClass}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
