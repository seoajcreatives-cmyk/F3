<!-- Script inline para procesamiento del formulario utilizando jQuery global y grecaptcha -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    const submitBtn = document.getElementById("submit_button");
    if (submitBtn) {
      submitBtn.addEventListener("click", sendmail);
    }
  });

  function sendmail(event) {
    if (event) event.preventDefault();
    if (!jQuery("#acept").is(":checked")) {
      alert("Please accept the Privacy Policy.");
      return false;
    }
    var captchaResponse = grecaptcha.getResponse();
    if (!captchaResponse) {
      alert("Please verify the reCAPTCHA.");
      return false;
    }

    jQuery("#submit_button").prop("disabled", true).text("SENDING...");
    jQuery("#load_form").show();

    var formData = {
      name: jQuery("#name").val(),
      lastName: jQuery("#lastName").val(),
      phone: jQuery("#phone").val(),
      email: jQuery("#email").val(),
      message: jQuery("#message").val(),
      "g-recaptcha-response": captchaResponse
    };

    fetch("https://hooks.zapier.com/hooks/catch/26423574/uelrxfz/", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        name: jQuery("#name").val(),
        last_name: jQuery("#lastName").val(),
        phone: jQuery("#phone").val(),
        email: jQuery("#email").val(),
        message: jQuery("#message").val(),
        privacy_consent: jQuery("#acept").is(":checked")
      })
    }).catch(err => console.log("Zapier error:", err));

    jQuery.post("/sendmail/send_contact.php", formData, function(result) {
      jQuery("#load_form").hide();
      jQuery("#submit_button").prop("disabled", false).text("SEND REQUEST");

      try {
        var res = JSON.parse(result);
        if (res.success) {
          jQuery("#message_box").html("<p style='color:#b71c1c; font-weight:700;'>Sent successfully!</p>").show();
          jQuery("#contact_form_id")[0].reset();
          grecaptcha.reset();
        } else {
          alert(res.message || "Error");
          grecaptcha.reset();
        }
      } catch (e) {
        alert("Sent, but check server response.");
      }
    });
  }
</script>
