---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import Reviews from '@components/Reviews.astro';
import { Image } from 'astro:assets';
import GoogleMap from '@components/GoogleMap.astro';
import Icon from '@components/Icon.astro';
import '../../styles/locations.css';
import '../../styles/internal-services.css';
import '../../styles/services.css';

// Metadatos
const metaTitle = "Construction Services – Central Islip, Long Island NY";
const metaDescription = "Remodeling and construction in Long Island, NY: kitchens, bathrooms, basement, siding, masonry, windows, doors, painting & power washing.";
const canonical = "https://f3constructionny.com/locations/290-earle-st-central.islip-ny-11722/";

// Resolver imagen de la oficina
const images = import.meta.glob<{ default: ImageMetadata }>('../../public/media/**/*.{jpeg,jpg,png,gif,webp,svg}');
const earleImgObj = images['../../public/media/jpg/290-earle.jpg'] ? (await images['../../public/media/jpg/290-earle.jpg']()).default : null;

// JSON-LD Schema
const locationSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://f3constructionny.com/#remodeling-construction-services",
  "serviceType": "Remodeling & Construction Services",
  "name": "Remodeling & Construction Services in Long Island, NY",
  "alternateName": "Home remodeling, renovations, and general contracting",
  "description": "Full-service remodeling and construction across Long Island, including kitchens, bathrooms, additions, exterior upgrades, and repairs—delivered with code-compliant workmanship and project management.",
  "provider": {
    "@type": "HomeAndConstructionBusiness",
    "name": "F3 Construction Corp",
    "@id": "https://f3constructionny.com/#business",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Earle St",
      "addressLocality": "Central Islip",
      "addressRegion": "NY",
      "postalCode": "11722",
      "addressCountry": "US"
    },
    "sameAs": [
      "https://www.facebook.com/f3construction/",
      "https://www.instagram.com/f3constructionny?igsh=dTZ2cTZ4NXp2aHRt"
    ]
  },
  "areaServed": [
    { "@type": "Place", "name": "Long Island, NY" },
    { "@type": "Place", "name": "Suffolk County, NY" },
    { "@type": "Place", "name": "Nassau County, NY" },
    { "@type": "Place", "name": "Central Islip, NY" },
    { "@type": "Place", "name": "Islip, NY" }
  ],
  "termsOfService": "https://f3constructionny.com/terms",
  "serviceOutput": "Code-compliant renovations and new construction with clean finishes, proper permits, inspections, and warranties.",
  "category": "Home remodeling, General contracting, Construction, Home improvement",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Remodeling & Construction Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Kitchen Remodeling",
          "description": "Layout updates, cabinetry, countertops, flooring, lighting, and plumbing."
        },
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Bathroom Renovation",
          "description": "Waterproofing, tile, vanities, fixtures, lighting, and ventilation."
        },
        "priceCurrency": "USD"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Decks & Additions",
          "description": "Design/build for room expansions and outdoor deck additions."
        },
        "priceCurrency": "USD"
      }
    ]
  },
  "offers": {
    "@type": "Offer",
    "url": "https://f3constructionny.com/",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "eligibleRegion": {
      "@type": "Place",
      "name": "Long Island, NY"
    }
  },
  "image": "https://f3constructionny.com/media/webp/png/logo.webp"
};

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<BaseLayout title={metaTitle} description={metaDescription} canonical={canonical}>
  <Fragment slot="head">
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(locationSchema)} />
  </Fragment>

  <main>
    <section id="banner-services">
      <div class="banner-container">
        <div class="banner-text">
          <h1>Remodeling & Construction Services in Long Island, NY</h1>
          <div class="banner-cta">
            <a href="https://maps.app.goo.gl/Sg6xbiQqSr33u8BU9" class="btn-banner" target="_blank">How to get there?</a>
          </div>
        </div>
      </div>
    </section>

    <Breadcrumb />

    <section class="about-f3-section">
      <div class="about-container">
        <div class="about-text">
          <h2>
            <center>Home renovation company in Long Island, NY</center>
          </h2>
          <section class="message-location">
            <div class="text-message">
              <p>F3 Construction is a full-service remodeling and construction company based in <strong>Central Islip, Long Island, NY.</strong></p>
              <p>With over 20 years of experience, our licensed and insured team provides reliable, high-quality home renovation solutions.</p>
              <p>From interior remodeling to exterior upgrades, we help homeowners bring their ideas to life — on time, on budget, and with unmatched attention to detail.</p>
              <div class="cta-button">
                <a href="tel:+16312788693" class="btn-contact">Call Us Today</a>
              </div>
            </div>
          </section>

          <section class="find-us-section">
            <div class="box-map">
              <div class="info-map">
                <h2>Where to Find Us in Long Island</h2>
                <p><strong>Address:</strong> 290 Earle St, Central Islip, NY 11722</p>
                <p><strong>Opening Hours:</strong><br />
                  Monday – Friday: 9:00 AM – 6:00 PM <br />
                  Saturday: 9:00 AM – 2:00 PM <br />
                  Sunday: Closed </p>
                <p><i class="fa-solid fa-location-dot"><Icon name="location-dot" /></i> View on Google Maps <i class="fa-solid fa-arrow-right"><Icon name="arrow-right" /></i></p>
                <p><strong>Contact</strong><br />
                  <a href="tel:+16312788693">(631) 278-8693</a>
                  <a href="mailto:f3ccorp@gmail.com">f3ccorp@gmail.com</a>
                </p>
              </div>
              <GoogleMap />
            </div>
          </section>

          <section class="about-f3-section">
            <div class="about-container">
              <div class="about-text">
                <h2>About F3 Construction as licensed general contractors in Central Islip, Long Island</h2>
                <p>For more than two decades, F3 Construction has served the Long Island community with dedication and craftsmanship.</p>
                <p>We specialize in <strong>kitchen and bathroom remodeling, siding installation, masonry, trim carpentry, window and door replacement, painting, and power washing.</strong></p>
                <p>Our mission is simple: deliver professional results that improve your home’s comfort, beauty, and value.</p>
                <p>We proudly serve <strong>Central Islip</strong> and nearby areas including <strong>Brentwood, Ronkonkoma, Hauppauge, Islip Terrace, and Suffolk County.</strong></p>
              </div>

              <div class="about-image">
                {earleImgObj && (
                  <Image 
                    src={earleImgObj} 
                    alt="F3 remodeler contractor in NY" 
                    loading="lazy"
                    width={1100}
                    height={900}
                  />
                )}
              </div>
            </div>
          </section>

          <section class="services-duo">
            <div class="service-box interior">
              <h2>Interior Remodeling</h2>
              <ul>
                <li><strong><a href={base + "services/kitchen-remodeling-long-island-ny"}>Kitchen Remodeling</a></strong>: Custom layouts, cabinets, countertops, backsplashes, lighting, and flooring.</li>
                <li><strong><a href={base + "services/bathroom-renovation-long-island-ny"}>Bathroom Renovation</a></strong>: Modern showers, tiles, vanities, and waterproof finishes.</li>
                <li><strong><a href={base + "services/trim-carpentry-services-long-island-ny"}>Trim Carpentry</a></strong>: Crown, baseboards, wainscoting, and detailed woodwork.</li>
                <li><strong><a href={base + "services/tile-installation-service-long-island-ny"}>Tile Installation</a></strong>: Wall, floor, and pattern tiling for kitchens, bathrooms, and basements.</li>
                <li><strong><a href={base + "services/house-painting-long-island-ny"}>Interior Painting</a></strong>: Clean, professional finishes that refresh your living spaces.</li>
                <li><strong><a href={base + "services/basement-solutions-long-island-ny"}>Basement Solutions</a></strong>: We discuss your vision, structural conditions, waterproofing needs, and budget to create a custom plan.</li>
                <li><strong><a href={base + "services/crown-molding-long-island-ny"}>Crown Molding</a></strong>: Elegant trim details that enhance ceilings and add a refined architectural touch.</li>
                <li><strong><a href={base + "services/house-painting-long-island-ny"}>House Painting</a></strong>: Smooth, high-quality finishes that refresh and protect your home inside and out.</li>
              </ul>
            </div>

            <div class="service-box exterior">
              <h2>Exterior Services</h2>
              <ul>
                <li><strong><a href={base + "services/deck-builders-long-island-ny"}>Decks Building</a></strong>: Design, build, or repair decks and covered porches.</li>
                <li><strong><a href={base + "services/siding-installation-long-island-ny"}>Siding Installation</a></strong>: Vinyl, fiber cement, and composite siding repairs or replacements.</li>
                <li><strong><a href={base + "services/masonry-contractors-long-island-ny"}>Masonry & Concrete Work</a></strong>: Brick, stone, steps, driveways, patios, and walkways.</li>
                <li><strong><a href={base + "services/replacement-windows-long-island-ny"}>Replacement Windows</a></strong> & <strong><a href={base + "services/door-installation-long-island-ny"}>Doors Installation</a></strong>: Energy-efficient replacement and installation for homes and patios.</li>
                <li><strong><a href={base + "services/power-washing-long-island-ny"}>Power Washing</a></strong>: Exterior cleaning for siding, decks, driveways, and post-construction projects.</li>
                <li><strong><a href={base + "services/portico-contractor-long-island-ny"}>Portico Construction</a></strong>: We use high-quality materials and skilled craftsmanship to build and restore porticos that increase your home’s value and charm.</li>
                <li><strong><a href={base + "services/replacement-windows-long-island-ny"}>Windows Replacement</a></strong>: Energy-efficient windows that improve comfort, insulation, and curb appeal.</li>
                <li><strong><a href={base + "services/patio-contractor-long-island-ny"}>Patio Contractor</a></strong>: Custom outdoor spaces designed for relaxation, entertainment, and durability.</li>
              </ul>
            </div>
          </section>

          <section class="directions-section">
            <div class="container">
              <h2 class="section-title">How to Get to F3 Construction</h2>
              <div class="directions-grid">
                <div class="direction-card">
                  <h3>By Car</h3>
                  <p>We’re located on Earle St, near Carlton Ave, just a few minutes from Southern State Parkway (Exit 43A).</p>
                  <p>It’s a quick 10–15 minute drive from Brentwood, Hauppauge, or Islip Terrace.</p>
                </div>
                <div class="direction-card">
                  <h3>By Train</h3>
                  <p>Take the LIRR to Central Islip Station.</p>
                  <p>We’re about a 4-minute (1.2 mile) drive via Lowell Ave and Earle St.</p>
                </div>
                <div class="direction-card">
                  <h3>By Bus</h3>
                  <p>Suffolk Transit Line <strong>S45</strong> stops at Carlton Ave / Smith St.</p>
                  <p>It’s a 5-minute walk to our office.</p>
                </div>
                <div class="direction-card">
                  <h3>Parking</h3>
                  <p>Free street parking on Earle St and nearby streets.</p>
                  <p>Public parking available during business hours.</p>
                </div>
              </div>

              <div class="directions-info">
                <p><strong>GPS Address:</strong> 290 Earle St, Central Islip, NY 11722</p>
                <p><strong>Service Area:</strong> Central Islip, Brentwood, Ronkonkoma, Hauppauge, Islip Terrace, Suffolk County</p>
                <p><strong>Accessibility:</strong> Accessible entrance & loading area available upon request.</p>
              </div>
            </div>
          </section>

          <section class="our-work">
            <div class="overlay"></div>
            <div class="container work-container">
              <div class="work-text">
                <h2>Our Work</h2>
                <p>Here’s a look at some of our recent remodeling and construction projects completed across Long Island and Central Islip:</p>
                <ul>
                  <li>Kitchen remodeling with modern cabinetry and lighting.</li>
                  <li>Bathroom renovation with walk-in showers.</li>
                  <li>Deck construction & composite repair work.</li>
                  <li>Masonry: driveways, walkways, steps & retaining walls.</li>
                  <li>Exterior painting & siding replacement.</li>
                </ul>
                <p class="note">We invite you to browse our gallery to see the quality and care in every project.</p>
              </div>
              <div class="work-button">
                <a href={base + "gallery"}>Gallery</a>
              </div>
            </div>
          </section>

          <section class="why-choose-f3">
            <div class="container">
              <h2>Why Homeowners Choose F3 Construction</h2>
              <ul class="why-list">
                <li>Over 20 years of proven experience in Long Island construction</li>
                <li>Licensed and insured professionals</li>
                <li>Clear project timelines and transparent pricing</li>
                <li>Local experts familiar with Suffolk County regulations</li>
                <li>Bilingual team (English & Spanish)</li>
                <li>Free on-site estimates and detailed consultations</li>
              </ul>
            </div>
            <div class="cta-button">
              <a href={base + "contact"} class="btn-contact">Contact Now</a>
            </div>
          </section>

          <section class="contact-form-section">
            <form id="contact_form_id" class="form-tag" method="post" novalidate>
              <div class="request-ctn">
                <div class="title">
                  <h2>CONNECT WITH US</h2>
                </div>
                
                <div class="form-ctn">
                  <input type="text" placeholder="Name" id="name" name="name" required />
                  <input type="text" placeholder="Last Name" id="lastName" name="lastName" required />
                  <input type="text" placeholder="Phone" id="phone" name="phone" required />
                  <input type="email" placeholder="Email" id="email" name="email" required />
                  <input type="text" placeholder="Message" id="message" name="message" required />
                </div>

                <div class="privacy-row">
                  <input type="checkbox" id="acept" name="accept" required />
                  <label for="acept">
                    I have read and accept the <a href={base + "privacy"} target="_blank">Privacy Policy</a>.
                  </label>
                </div>

                <!-- Google reCAPTCHA -->
                <div class="g-recaptcha" data-sitekey="6Lc2YOsrAAAAANLQTo2_5XtXZqgH0neFNyTRMAhU"></div>

                <div class="submit-btn">
                  <button type="button" id="submit_button" class="btn-submit-gtm">SEND REQUEST</button>
                </div>

                <div class="notify_box">
                  <div class="loader" id="load_form" style="display:none; margin: 10px auto;"></div>
                  <div class="message_box" id="message_box"></div>
                </div>
              </div>
            </form>
          </section>

          <div class="contact-box">
            <h3>Request a Free Estimate</h3>
            <p>Ready to begin your next home improvement project in Central Islip?</p>
            <div class="contact-lines">
              <p><strong>Call:</strong> <a href="tel:+16312788693">(631) 278-8693</a></p>
              <p><strong>Email:</strong> <a href="mailto:f3ccorp@gmail.com">f3ccorp@gmail.com</a></p>
              <p><strong>Visit:</strong> <a href={base}>f3constructionny.com</a></p>
            </div>
          </div>

          <section class="testimonial-section">
            <h2>Testimonials</h2>
            <p>See what Long Island homeowners say about our services:</p>
            <Reviews />
          </section>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    const submitBtn = document.getElementById("submit_button");
    if (submitBtn) {
      submitBtn.addEventListener("click", sendmail);
    }
  });

  function sendmail(event) {
    if (event) event.preventDefault();
    
    const aceptCheck = document.getElementById("acept");
    if (aceptCheck && !aceptCheck.checked) {
      alert("Please accept the Privacy Policy.");
      return false;
    }
    
    var captchaResponse = typeof grecaptcha !== "undefined" ? grecaptcha.getResponse() : "";
    if (!captchaResponse) {
      alert("Please verify the reCAPTCHA.");
      return false;
    }

    const submitBtn = document.getElementById("submit_button");
    const loaderEl = document.getElementById("load_form");

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "SENDING...";
    }
    if (loaderEl) {
      loaderEl.style.display = "block";
    }

    const nameVal = document.getElementById("name")?.value || "";
    const lastNameVal = document.getElementById("lastName")?.value || "";
    const phoneVal = document.getElementById("phone")?.value || "";
    const emailVal = document.getElementById("email")?.value || "";
    const messageVal = document.getElementById("message")?.value || "";

    var formData = {
      name: nameVal,
      lastName: lastNameVal,
      phone: phoneVal,
      email: emailVal,
      message: messageVal,
      "g-recaptcha-response": captchaResponse
    };

    // Envío principal al script PHP ubicado en la ruta absoluta
    const contactForm = document.getElementById("contact_form_id");
    var base = contactForm ? (contactForm.getAttribute("data-base") || "/") : "/";
    
    var urlParams = new URLSearchParams(formData);

    fetch(base + "sendmail/send_contact.php", {
      method: "POST",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded"
      },
      body: urlParams
    })
    .then(response => response.text())
    .then(result => {
      if (loaderEl) loaderEl.style.display = "none";
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "SEND REQUEST";
      }

      try {
        var res = JSON.parse(result);
        if (res.success) {
          const msgBox = document.getElementById("message_box");
          if (msgBox) {
            msgBox.innerHTML = "<p style='color:#b71c1c; font-weight:700;'>Sent successfully!</p>";
            msgBox.style.display = "block";
          }
          if (contactForm) {
            contactForm.reset();
          }
          grecaptcha.reset();
        } else {
          alert(res.message || "Error");
          grecaptcha.reset();
        }
      } catch (e) {
        alert("Sent, but check server response.");
      }
    })
    .catch(err => {
      if (loaderEl) loaderEl.style.display = "none";
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "SEND REQUEST";
      }
      alert("An error occurred during submission.");
    });
  }
</script>
