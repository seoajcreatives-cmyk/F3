<!-- Scripts lógicos de efectos de carrusel y círculo de seguimiento -->
<script>
  // Autoscroll del carrusel de servicios
  const carousel = document.querySelector('.carousel_box') as HTMLElement;
  const scrollAmount = 350;
  const stepTime = 3000;

  function autoScroll() {
    if (!carousel) return;
    if (carousel.scrollLeft + carousel.offsetWidth >= carousel.scrollWidth) {
      carousel.scrollTo({
        left: 0,
        behavior: 'smooth'
      });
    } else {
      carousel.scrollBy({
        left: scrollAmount,
        behavior: 'smooth'
      });
    }
  }

  if (carousel) {
    let scrollInterval = setInterval(autoScroll, stepTime);

    carousel.addEventListener('mouseenter', () => clearInterval(scrollInterval));
    carousel.addEventListener('mouseleave', () => scrollInterval = setInterval(autoScroll, stepTime));

    // Efecto de seguimiento del ratón del círculo en la sección services
    const circle = document.querySelector(".circle") as HTMLElement;
    const container = document.querySelector(".box-text") as HTMLElement;

    if (container && circle) {
      container.addEventListener("mousemove", (a: MouseEvent) => {
        const rect = container.getBoundingClientRect();
        // Calculamos la posición relativa al contenedor para que funcione bien con scroll
        circle.style.top = (a.clientY - rect.top) + "px";
        circle.style.left = (a.clientX - rect.left) + "px";
      });
    }
  }
</script>
