---
// src/components/Reviews2.astro
import '../styles/review.css';
import '../styles/review2.css';
import '../styles/internal-services.css';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" /></noscript>

<!-- Swiper Container -->
<div class="swiper review-slider2">
  <div class="swiper-wrapper">
    <!-- Review 8 -->
    <div class="swiper-slide review-card">
      <div class="review-header">
        <div class="review-avatar">
          <img src={base + "media/png/review-8.png"} alt="Review 8" loading="lazy" width="72" height="72" style="width: 72px; height: 72px; object-fit: cover; border-radius: 50%;" />
        </div>
        <div>
          <h3 class="review-name">Solange Guirand</h3>
          <div class="review-stars">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
          </div>
          <p class="review-time">2 Weeks Ago</p>
        </div>
      </div>
      <p class="review-text">
        The staff was incredibly attentive and helped me find exactly what I needed. Their attention to details 
        made the whole process smooth and stress free. I will definitely be back and recommend them to all my friends. Services Home renovations
      </p>
      <a href="https://maps.app.goo.gl/AjKKPtq26tpNSJgB7" class="review-link" target="_blank" rel="noopener noreferrer">Read More</a>
    </div>

    <!-- Review 9 -->
    <div class="swiper-slide review-card">
      <div class="review-header">
        <div class="review-avatar">
          <img src={base + "media/png/review-9.png"} alt="Review 9" loading="lazy" width="72" height="72" style="width: 72px; height: 72px; object-fit: cover; border-radius: 50%;" />
        </div>
        <div>
          <h3 class="review-name">William ODonnell</h3>
          <div class="review-stars">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
          </div>
          <p class="review-time">A Year Ago</p>
        </div>
      </div>
      <p class="review-text">
        The best construction company out there. Highly reliable and reasonable!
      </p>
      <a href="https://maps.app.goo.gl/4BNFcbrQuZg6tYm78" class="review-link" target="_blank" rel="noopener noreferrer">Read More</a>
    </div>

    <!-- Review 10 -->
    <div class="swiper-slide review-card">
      <div class="review-header">
        <div class="review-avatar">
          <img src={base + "media/png/review-10.png"} alt="Review 10" loading="lazy" width="72" height="72" style="width: 72px; height: 72px; object-fit: cover; border-radius: 50%;" />
        </div>
        <div>
          <h3 class="review-name">Robert Massey</h3>
          <div class="review-stars">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
          </div>
          <p class="review-time">A Year Ago</p>
        </div>
      </div>
      <p class="review-text">
        I have used F3 for my bathroom, kitchen, and now my living room and bedroom. Orman and his team have consistently done excellent work. He cares about his clients and his craft. I am very pleased with the results of my renovations. Services Home renovations, Remodelling!
      </p>
      <a href="https://maps.app.goo.gl/DuBrAb4bFJjgUZTA7" class="review-link" target="_blank" rel="noopener noreferrer">Read More</a>
    </div>

    <!-- Review 11 -->
    <div class="swiper-slide review-card">
      <div class="review-header">
        <div class="review-avatar">
          <img src={base + "media/png/review-11.png"} alt="Review 11" loading="lazy" width="72" height="72" style="width: 72px; height: 72px; object-fit: cover; border-radius: 50%;" />
        </div>
        <div>
          <h3 class="review-name">Lisa Carabott</h3>
          <div class="review-stars">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
          </div>
          <p class="review-time">A Year Ago</p>
        </div>
      </div>
      <p class="review-text">
        From initial consultation to the final walkthrough, the entire team was professional, friendly, respectful of our home and incredibly skilled. Olman gave recommendations along the way that brought our deck project to a perfect outcome. Craftsmanship is outstanding- every detail superb, our finished project looks amazing. They completed the project ahead of schedule and even power washed the entire area and left it better than they found it.
      </p>
      <a href="https://maps.app.goo.gl/NS9tmVzCvTmkegSQ6" class="review-link" target="_blank" rel="noopener noreferrer">Read More</a>
    </div>

    <!-- Review 12 -->
    <div class="swiper-slide review-card">
      <div class="review-header">
        <div class="review-avatar">
          <img src={base + "media/png/review-12.png"} alt="Review 12" loading="lazy" width="72" height="72" style="width: 72px; height: 72px; object-fit: cover; border-radius: 50%;" />
        </div>
        <div>
          <h3 class="review-name">OLGA RODRIGUEZ</h3>
          <div class="review-stars">
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
            <i class="fas fa-star"></i>
          </div>
          <p class="review-time">A Year Ago</p>
        </div>
      </div>
      <p class="review-text">
        My husband and I Have been renovating our home on and off for years. We are very familiar with contractors and working with different types of projects and companies. I have to say that we have had the best experience with F3 construction. We had received Different estimates from various companies and they were the most economical. At first, we were hesitant because you get what you pay for, but they were fantastic. They cleaned up after themselves and did the work during the time frame stated. More importantly, the quality of the work was very, very good.
      </p>
      <a href="https://maps.app.goo.gl/jj5kZaNZj69xAvqw7" class="review-link" target="_blank" rel="noopener noreferrer">Read More</a>
    </div>
  </div>

  <div class="swiper-pagination"></div>
</div>

<script>
  // Carga no bloqueante de Swiper mediante importación dinámica
  import('https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs').then(({ default: Swiper }) => {
    const initSwiper2 = () => {
      const sliderEl = document.querySelector(".review-slider2");
      if (sliderEl) {
        new Swiper(".review-slider2", {
          slidesPerView: 1,
          spaceBetween: 20,
          loop: true,
          autoplay: {
            delay: 33000,
            disableOnInteraction: false,
          },
          pagination: {
            el: ".swiper-pagination",
            clickable: true,
          },
          breakpoints: {
            768: {
              slidesPerView: 1,
            },
          },
        });
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSwiper2);
    } else {
      initSwiper2();
    }
  });
</script>
