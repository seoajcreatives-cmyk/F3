// src/components/Tracker.astro
---
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-N5BNJZJB"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<script is:inline>
  (function() {
    let trackersInitialized = false;
    let timeoutId = null;

    function initTrackers() {
      if (trackersInitialized) return;
      trackersInitialized = true;

      // Limpiar el timeout de seguridad si se activa por interacción del usuario
      if (timeoutId) {
        clearTimeout(timeoutId);
      }

      // 1. Google Tag (gtag.js)
      const gtagScript = document.createElement('script');
      gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=G-PFCD90JNJ7";
      gtagScript.async = true;
      document.head.appendChild(gtagScript);

      gtagScript.onload = () => {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-PFCD90JNJ7');
      };

      // 2. Google Tag Manager
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-N5BNJZJB');

      // 3. Microsoft Clarity
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "tqlfr5xzsw");
    }

    // Escuchar eventos de interacción común para activar trackers
    const triggerEvents = ['mousedown', 'mousemove', 'keypress', 'scroll', 'touchstart'];
    triggerEvents.forEach(event => {
      window.addEventListener(event, initTrackers, { once: true, passive: true });
    });

    // Fallback de seguridad: 3.5 segundos para no perder rebotadores
    timeoutId = setTimeout(initTrackers, 3500);
  })();
</script>
