---
// src/components/Blogs.astro
interface Post {
  title: { rendered: string };
  link: string;
  date: string;
  _embedded?: {
    'wp:featuredmedia'?: Array<{ source_url: string }>;
  };
}

let posts: Post[] = [];
try {
  const response = await fetch("https://www.f3constructionny.com/blog/wp-json/wp/v2/posts?per_page=3&_embed");
  if (response.ok) {
    posts = await response.json() as Post[];
  }
} catch (e) {
  console.error("Error fetching WordPress posts:", e);
}

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

{posts.map((post) => {
  const title = post.title.rendered;
  const link = post.link;
  const date = new Date(post.date).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric"
  });
  const image = post._embedded?.['wp:featuredmedia']?.[0]?.source_url || "";
  
  return (
    <div class="blog-card">
      <div class="blog-image" style="aspect-ratio: 400 / 250; overflow: hidden; background-color: #eee;">
        {image && (
          <img 
            src={image} 
            alt={title} 
            loading="lazy" 
            width="400" 
            height="250" 
            style="width: 100%; height: 100%; object-fit: cover; display: block;" 
          />
        )}
      </div>
      <div class="blog-content">
        <h3>{title}</h3>
        <p class="blog-date">{date}</p>
        <a href={link} class="read-btn"><span>Read more</span></a>
      </div>
    </div>
  );
})}
