---
// src/components/Header.astro
import { Image } from 'astro:assets';
import bbbLogo from '../../public/media/png/acreditation-f3-2.png';
import bbbLogoMobile from '../../public/media/png/acreditation-f3-2-1.png';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<header>
  <div class="line-address">
    <a href="https://goo.gl/maps/2JWRRVgKfv4YvGaCA" target="_blank">
      <i class="fa-solid fa-location-dot"></i>290 Earle St. Central Islip, NY 11722
    </a>
    <a href="tel:+16312788693">
      <i class="fa-solid fa-phone"></i>631-278-8693
    </a>
    <a href="mailto:f3construction@gmail.com">
      <i class="fa-solid fa-envelope"></i>f3construction@gmail.com
    </a>
    <div class="social-icon">
      <a id="btn_social" href="https://www.facebook.com/f3construction/" target="_blank" aria-label="Facebook">
        <i class="fa-brands fa-facebook-f"></i>
      </a>
      <a id="btn_social" href="https://www.tiktok.com/@f3construction_ny" target="_blank" aria-label="tiktok">
        <i class="fa-brands fa-tiktok"></i>
      </a>
      <a id="btn_social" href="https://www.instagram.com/f3constructionny?igsh=dTZ2cTZ4NXp2aHRt" target="_blank" aria-label="instagram">
        <i class="fa-brands fa-instagram"></i>
      </a>
      <a id="btn_social" href="https://www.google.com/search?hl=en&authuser=0&gl=co&output=search&q=F3+Construction+Corp&ludocid=4353299437963021024&gsas=1&lsig=AB86z5Uhqch1JIsGnD4QLuWF2d_2&ved=1i%3A2%2Ct%3A109124%2Ce%3A1%2Cp%3AZmLZY8WEOZ6BkvQPiICT8Ac%3A1" target="_blank" aria-label="gmb">
        <i class="fa-solid fa-store"></i>
      </a>
      <a id="btn_social" href="https://yelp.com/biz/f3-construction-central-islip" target="_blank" aria-label="yelp">
        <i class="fa-brands fa-yelp"></i>
      </a>
    </div>
  </div>
  
  <div class="header-desktop">
    <div class="header-left">
      <div class="logo" style="width: 160px; height: 109px; flex-shrink: 0; display: block;">
        <a href={base} aria-label="F3 Construction Logo" style="display: block; width: 100%; height: 100%;">
          <img class="primary-logo" 
               src={base + "media/webp/png/logo.webp"} 
               alt="F3 Construction" 
               width="300" 
               height="205" 
               style="width: 100%; height: auto; display: block; aspect-ratio: 300 / 205;"
               fetchpriority="high" />
        </a>
      </div>
      <div class="menu">
        <ul>
          <li><a href={base}>Home</a></li>
          <li><a href={base + "about"}>About Us</a></li>

          <li class="dropdown">
            <a href={base + "services"}>Services <i class="fa-solid fa-angle-down"></i></a>
            <ul class="dropdown-menu">
              <li><a href={base + "services/kitchen-remodeling-long-island-ny"}>Kitchen Remodeling</a></li>
              <li><a href={base + "services/deck-builders-long-island-ny"}>Deck Building</a></li>
              <li><a href={base + "services/crown-molding-long-island-ny"}>Crown Molding</a></li>
              <li><a href={base + "services/portico-contractor-long-island-ny"}>Portico Construction</a></li>
              <li><a href={base + "services/tile-installation-service-long-island-ny"}>Tile Installation</a></li>
              <li><a href={base + "services/siding-installation-long-island-ny"}>Siding Installation</a></li>
              <li><a href={base + "services/bathroom-renovation-long-island-ny"}>Bathroom Renovation</a></li>
              <li><a href={base + "services/masonry-contractors-long-island-ny"}>Masonry Contractor</a></li>
              <li><a href={base + "services/trim-carpentry-services-long-island-ny"}>Trim Carpentry</a></li>
              <li><a href={base + "services/replacement-windows-long-island-ny"}>Window Replacement</a></li>
              <li><a href={base + "services/door-installation-long-island-ny"}>Door Installation</a></li>
              <li><a href={base + "services/house-painting-long-island-ny"}>House Painting</a></li>
              <li><a href={base + "services/power-washing-long-island-ny"}>Power Washing</a></li>
              <li><a href={base + "services/basement-solutions-long-island-ny"}>Basement Solutions</a></li>
              <li><a href={base + "services/patio-contractor-long-island-ny"}>Patio Contractor</a></li>
            </ul>
          </li>

          <li><a href={base + "gallery"}>Gallery</a></li>
          <li><a href={base + "contact"}>Contact</a></li>

          <li class="dropdown">
            <a href="/blog">Blog <i class="fa-solid fa-angle-down"></i></a>
            <ul class="dropdown-menu">
              <li><a href="https://f3constructionny.com/blog/category/kitchen-renovation-guides/">Kitchen Renovation Guides</a></li>
              <li><a href="https://f3constructionny.com/blog/category/deck-construction-insights/">Deck Construction Insights</a></li>
              <li><a href="https://f3constructionny.com/blog/category/crown-molding-resources/">Crown Molding Resources</a></li>
              <li><a href="https://f3constructionny.com/blog/category/portico-style-inspiration/">Portico Style Inspiration</a></li>
              <li><a href="https://f3constructionny.com/blog/category/tile-remodeling-ideas/">Tile Remodeling Ideas</a></li>
              <li><a href="https://f3constructionny.com/blog/category/home-siding-improvement/">Home Siding Improvement</a></li>
              <li><a href="https://f3constructionny.com/blog/category/bath-remodeling-tips/">Bath Remodeling Tips</a></li>
              <li><a href="https://f3constructionny.com/blog/category/masonry-craftsmanship-tutorials/">Masonry Craftsmanship Tutorials</a></li>
            </ul>
          </li>
        </ul>
      </div>
      
      <div class="bbb-logo" style="width: 150px; height: 57px; flex-shrink: 0; display: block;">
        <a href="https://www.bbb.org/us/ny/central-islip/profile/home-improvement/f3-constructions-corp-0121-87182765" style="display: block; width: 100%; height: 100%;">
          <Image src={bbbLogo} alt="BBB" width={150} height={57} format="webp" quality={85} style="width: 100%; height: auto; display: block; aspect-ratio: 150 / 57;" />
        </a>
      </div>
    </div>

    <div class="header-right">
      <div class="contact-button">
        <a href={base + "contact"}>Free Quote Service</a>
      </div>
    </div>
  </div>

  <div class="mobile-header" id="mobile-header">
    <div class="mobile-header-container">
      <div style="width: 120px; aspect-ratio: 300 / 205; flex-shrink: 0; overflow: hidden; display: block;">
        <a href={base} aria-label="logo" style="display: block; width: 100%; height: 100%;">
          <img class="primary-logo" 
               src={base + "media/webp/png/logo.webp"} 
               alt="F3 Construction" 
               width="300" 
               height="205" 
               style="width: 100%; height: auto; display: block; aspect-ratio: 300 / 205; object-fit: contain;" />
        </a>
      </div>
      <div class="mobile_toggle">
        <hr />
        <hr />
        <hr />
      </div>
      <div class="mobile_blur"></div>

      <div class="side-bar-box">
        <ul class="menu">
          <li><a href={base}> Home</a></li>
          <li><a href={base + "about"}> About Us</a></li>
          <li><a href={base + "services"}>Services</a></li>

          <li class="dropdown">
            <p><i class="fa-solid fa-angle-down"></i></p>
            <ul class="dropdown-menu">
              <li><a href={base + "services/kitchen-remodeling-long-island-ny"}>Kitchen Remodeling</a></li>
              <li><a href={base + "services/deck-builders-long-island-ny"}>Deck Building</a></li>
              <li><a href={base + "services/crown-molding-long-island-ny"}>Crown Molding</a></li>
              <li><a href={base + "services/portico-contractor-long-island-ny"}>Portico Construction</a></li>
              <li><a href={base + "services/tile-installation-service-long-island-ny"}>Tile Installation</a></li>
              <li><a href={base + "services/siding-installation-long-island-ny"}>Siding Installation</a></li>
              <li><a href={base + "services/bathroom-renovation-long-island-ny"}>Bathroom Renovation</a></li>
              <li><a href={base + "services/masonry-contractors-long-island-ny"}>Masonry</a></li>
              <li><a href={base + "services/trim-carpentry-services-long-island-ny"}>Trim Carpentry</a></li>
              <li><a href={base + "services/replacement-windows-long-island-ny"}>Window Replacement</a></li>
              <li><a href={base + "services/door-installation-long-island-ny"}>Door Installation</a></li>
              <li><a href={base + "services/house-painting-long-island-ny"}>House Painting</a></li>
              <li><a href={base + "services/power-washing-long-island-ny"}>Power Washing</a></li>
              <li><a href={base + "services/basement-solutions-long-island-ny"}>Basement Solutions</a></li>
              <li><a href={base + "services/patio-contractor-long-island-ny"}>Patio Contractor</a></li>
            </ul>
          </li>

          <li><a href={base + "gallery"}> Gallery</a></li>
          <li><a href={base + "contact"}> Contact</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>

        <a href="https://www.bbb.org/us/ny/central-islip/profile/home-improvement/f3-constructions-corp-0121-87182765">
          <Image src={bbbLogoMobile} alt="BBB" width={150} height={57} format="webp" quality={85} style="width: 100%; height: auto;" />
        </a>

        <div class="button-header-mobile">
          <a id="btn_social" href="https://www.facebook.com/f3construction/" target="_blank" aria-label="Facebook">
            <i class="fa-brands fa-facebook-f"></i>
          </a>
          <a id="btn_social" href="https://www.tiktok.com/@f3ccorp" target="_blank" aria-label="tiktok">
            <i class="fa-brands fa-tiktok"></i>
          </a>
          <a id="btn_social" href="https://www.instagram.com/f3ccorp/" target="_blank" aria-label="instagram">
            <i class="fa-brands fa-instagram"></i>
          </a>
          <a id="btn_social" href="https://www.google.com/search?hl=en&authuser=0&gl=co&output=search&q=F3+Construction+Corp&ludocid=4353299437963021024&gsas=1&lsig=AB86z5Uhqch1JIsGnD4QLuWF2d_2&ved=1i%3A2%2Ct%3A109124%2Ce%3A1%2Cp%3AZmLZY8WEOZ6BkvQPiICT8Ac%3A1" target="_blank" aria-label="gmb">
            <i class="fa-solid fa-store"></i>
          </a>
          <a id="btn_social" href="https://yelp.com/biz/f3-construction-central-islip" target="_blank" aria-label="yelp">
            <i class="fa-brands fa-yelp"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function active_toggle() {
    document.querySelector("#mobile-header")?.classList.toggle("toggle_active");
    document.querySelector(".mobile_toggle")?.classList.toggle("close_toggle");
  }

  document.querySelector(".mobile_toggle")?.addEventListener("click", active_toggle);
  document.querySelector(".mobile_blur")?.addEventListener("click", active_toggle);
</script>
